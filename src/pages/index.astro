---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AboutMe from '../components/AboutMe.astro';
import ExperienceEducation from '../components/ExperienceEducation.astro';
import Projects from '../components/Projects.jsx';
import ContactForm from '../components/ContactForm.jsx';
import ScrollEnhancer from '../components/ScrollEnhancer.jsx';
import Galaxy from "../components/Galaxy.jsx";
import '../styles/global.css';

---

<Layout>
	<ScrollEnhancer client:load />
	<div class="galaxy-bg" aria-hidden="true">
		<Galaxy
			client:load
			mouseRepulsion={true}
			mouseInteraction={false}
			density={0.8}
			glowIntensity={0.22}
			saturation={0}
			hueShift={255}
			twinkleIntensity={0.2}
			rotationSpeed={0.06}
			repulsionStrength={2}
			autoCenterRepulsion={0}
			starSpeed={0.42}
			speed={0.6}
			quality={0.55}
			maxFps={25}
		/>
	</div>

	<div class="page-shell">
		<Hero />

		<AboutMe />

		<ExperienceEducation />

		<Projects client:load />
		<ContactForm client:load />
	</div>
</Layout>
