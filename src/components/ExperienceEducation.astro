---
/** Combined Experience + Education with tab toggle */
---

<section
	id="experience"
	class="section section-reveal journey"
	aria-labelledby="journey-heading"
>
	<div class="section-head journey__head">
		<h2 id="journey-heading" class="section-title">What I Work On</h2>
		<p class="journey__sub" data-journey-sub>
			Robotics leadership, full-stack delivery, and collaboration — switch tabs to see education.
		</p>

		<div class="journey__tabs" role="tablist" aria-label="Experience or education">
			<button
				type="button"
				class="journey__tab journey__tab--active"
				role="tab"
				id="journey-tab-exp"
				aria-controls="journey-panel-exp"
				aria-selected="true"
				data-journey-tab="experience"
			>
				<svg class="journey__tab-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
					<path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
				</svg>
				Experience
			</button>
			<button
				type="button"
				class="journey__tab"
				role="tab"
				id="journey-tab-edu"
				aria-controls="journey-panel-edu"
				aria-selected="false"
				data-journey-tab="education"
			>
				<svg class="journey__tab-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
					></path>
				</svg>
				Education
			</button>
		</div>
	</div>

	<div
		id="journey-panel-exp"
		class="journey__panel journey__panel--active"
		role="tabpanel"
		aria-labelledby="journey-tab-exp"
		data-journey-panel="experience"
	>
		<ul class="timeline-v2">
			<li class="timeline-v2__item">
				<div class="timeline-v2__rail" aria-hidden="true">
					<span class="timeline-v2__icon-wrap">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
							<path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
						</svg>
					</span>
					<span class="timeline-v2__stem"></span>
				</div>
				<article class="timeline-v2__card">
					<header class="timeline-v2__card-head">
						<h3 class="timeline-v2__title">Vice President</h3>
						<p class="timeline-v2__org">UTM Robocon Team</p>
						<p class="timeline-v2__dates">July 2024 – June 2025</p>
					</header>
					<div class="timeline-v2__body">
						<p>
							<strong>Strategic Leadership:</strong> Spearheaded operational initiatives and cultivated the next
							generation of robotics talent by orchestrating major events, including the Autocar Program, Junior
							Mini Games, and foundational workshops.
						</p>
						<p>
							<strong>Full-Stack Web Maintenance:</strong> Engineered and modernized the UTM Robocon web platform,
							significantly enhancing user experience, functionality, and overall content accessibility.
						</p>
						<p>
							<strong>Robotics Interface Architecture:</strong> Developed the frontend interface for the
							team&apos;s competition application, seamlessly integrating UI components with ROS-based robot
							telemetry to display live, real-time coordinate tracking.
						</p>
						<p>
							<strong>Cross-Functional Collaboration:</strong> Bridged the gap between the software and hardware
							divisions, establishing robust communication pipelines to ensure flawless synchronization between our
							applications and physical robot systems.
						</p>
					</div>
					<div class="timeline-v2__tags">
						<span class="timeline-v2__tag">Event Management</span>
						<span class="timeline-v2__tag">Web Development</span>
						<span class="timeline-v2__tag">ROS / Robotics</span>
						<span class="timeline-v2__tag">Leadership</span>
					</div>
				</article>
			</li>

			<li class="timeline-v2__item timeline-v2__item--last">
				<div class="timeline-v2__rail" aria-hidden="true">
					<span class="timeline-v2__icon-wrap">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
							<path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
						</svg>
					</span>
				</div>
				<article class="timeline-v2__card">
					<header class="timeline-v2__card-head">
						<h3 class="timeline-v2__title">Software Member (Junior Trainee)</h3>
						<p class="timeline-v2__org">UTM Robocon Team</p>
						<p class="timeline-v2__dates">July 2023 – June 2024</p>
					</header>
					<div class="timeline-v2__body">
						<p>
							<strong>Rapid Skill Acquisition:</strong> Immersed myself in an intensive junior training program,
							quickly mastering the fundamentals of both robotics programming and modern web development.
						</p>
						<p>
							<strong>Hands-On Web Design:</strong> Translated theory into practice by building and styling
							foundational web components using HTML and CSS under the mentorship of senior engineers.
						</p>
						<p>
							<strong>Systems Integration:</strong> Actively contributed to internal technical projects, building a
							deep, practical understanding of complex robotics systems and software-hardware integration.
						</p>
					</div>
					<div class="timeline-v2__tags">
						<span class="timeline-v2__tag">HTML / CSS</span>
						<span class="timeline-v2__tag">Web Development</span>
						<span class="timeline-v2__tag">Robotics Programming</span>
					</div>
				</article>
			</li>
		</ul>
	</div>

	<div
		id="journey-panel-edu"
		class="journey__panel"
		role="tabpanel"
		aria-labelledby="journey-tab-edu"
		hidden
		data-journey-panel="education"
	>
		<ul class="timeline-v2">
			<li class="timeline-v2__item">
				<div class="timeline-v2__rail" aria-hidden="true">
					<span class="timeline-v2__icon-wrap timeline-v2__icon-wrap--edu">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
							></path>
						</svg>
					</span>
					<span class="timeline-v2__stem"></span>
				</div>
				<article class="timeline-v2__card timeline-v2__card--badged">
					<span class="timeline-v2__badge">Current</span>
					<header class="timeline-v2__card-head">
						<h3 class="timeline-v2__title">Bachelor of Computer Science (Software Engineering) · 3rd Year</h3>
						<p class="timeline-v2__org">Universiti Teknologi Malaysia (UTM)</p>
						<p class="timeline-v2__dates">2023 – 2027 (Expected)</p>
					</header>
					<div class="timeline-v2__body">
						<p>Building a rigorous foundation in software architecture and development.</p>
						<p>
							<strong>Relevant coursework:</strong> Data Structures, Algorithms, Mobile Development, and Software
							Engineering.
						</p>
					</div>
				</article>
			</li>

			<li class="timeline-v2__item timeline-v2__item--last">
				<div class="timeline-v2__rail" aria-hidden="true">
					<span class="timeline-v2__icon-wrap timeline-v2__icon-wrap--edu">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
							></path>
						</svg>
					</span>
				</div>
				<article class="timeline-v2__card">
					<header class="timeline-v2__card-head">
						<h3 class="timeline-v2__title">Matriculation — Physical Science</h3>
						<p class="timeline-v2__org">Kolej Matrikulasi Pahang</p>
						<p class="timeline-v2__dates">2022 – 2023</p>
					</header>
					<div class="timeline-v2__body">
						<p>
							Developed a strong analytical and quantitative framework through intensive foundation studies in
							Mathematics, Physics, and Chemistry to prepare for the engineering pathway.
						</p>
					</div>
				</article>
			</li>
		</ul>
	</div>
</section>

<script>
	const subCopy = {
		experience:
			"Robotics leadership, full-stack delivery, and collaboration — switch tabs to see education.",
		education: "Universities and programs that built my foundation in software and engineering.",
	};

	function initJourney() {
		const subEl = document.querySelector("[data-journey-sub]");
		const tabs = document.querySelectorAll("[data-journey-tab]");
		const panels = document.querySelectorAll("[data-journey-panel]");

		tabs.forEach((tab) => {
			tab.addEventListener("click", () => {
				const name = tab.getAttribute("data-journey-tab");
				if (!name) return;

				tabs.forEach((t) => {
					const active = t === tab;
					t.classList.toggle("journey__tab--active", active);
					t.setAttribute("aria-selected", active ? "true" : "false");
				});

				panels.forEach((p) => {
					const match = p.getAttribute("data-journey-panel") === name;
					p.toggleAttribute("hidden", !match);
					p.classList.toggle("journey__panel--active", match);
				});

				if (subEl && (name === "experience" || name === "education")) {
					subEl.textContent = subCopy[name];
				}
			});
		});
	}

	initJourney();
</script>
